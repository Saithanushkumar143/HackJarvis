# ═══════════════════════════════════════════════════════
#  JARVIS — Environment Configuration
#  Copy this to .env and fill in your keys
# ═══════════════════════════════════════════════════════

# ── AI Brain ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get free key: https://aistudio.google.com/app/apikey

# ── Weather ───────────────────────────────────────────
WEATHER_API_KEY=your_weatherapi_key_here
# Free at: https://www.weatherapi.com

# ── News ──────────────────────────────────────────────
GNEWS_API_KEY=your_gnews_api_key_here
# Free at: https://gnews.io

# ── WolframAlpha (Math) ───────────────────────────────
WOLFRAM_API_KEY=your_wolfram_api_key_here
# Free at: https://products.wolframalpha.com/api

# ── n8n Automation Webhook ────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/jarvis
# Set up n8n locally: https://n8n.io

# ── Email (optional) ──────────────────────────────────
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_specific_password

# ── WhatsApp ──────────────────────────────────────────
WHATSAPP_SHORTCUT_PATH=C:\Users\YourName\OneDrive\Desktop\WhatsApp.lnk

# ── User Settings ─────────────────────────────────────
USER_NAME=Sir
ASSISTANT_NAME=Jarvis
WAKE_WORD=jarvis
CITY=Hyderabad
COUNTRY=India

# ── Voice Settings ────────────────────────────────────
# 0 = Male (SAPI5 voice index), 1 = Female
VOICE_INDEX=1
SPEECH_RATE=170

# ── Offline Mode ──────────────────────────────────────
# If true, uses only local models when internet unavailable
OFFLINE_FALLBACK=true
